generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════════════
//  USER
// ══════════════════════════════════════════════
model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  username    String   @unique
  displayName String
  email       String
  avatarUrl   String?
  bio         String?
  location    String?
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // stats
  eloRating     Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastSolvedAt  DateTime?

  // leaderboard
  weeklyScore   Int       @default(0)
  bestRank      Int? // best weekly leaderboard rank ever achieved

  // relations
  problems       Problem[]
  submissions    Submission[]
  followedBy     Follow[]        @relation("following") // people who follow this user
  following      Follow[]        @relation("follower") // people this user follows
  likes          Like[]
  comments       Comment[]
  notifications  Notification[]  @relation("recipient")
  solvedProblems SolvedProblem[]
  bookmarks      Bookmark[]
  conversations  ConversationParticipant[]
  sentMessages   Message[]

  @@index([clerkId])
  @@index([username])
}

// ══════════════════════════════════════════════
//  PROBLEM
// ══════════════════════════════════════════════
model Problem {
  id          String     @id @default(cuid())
  authorId    String // FK → User.id
  slug        String     @unique
  title       String
  summary     String
  description String     @db.Text // full markdown
  difficulty  Difficulty
  constraints String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  likesCount       Int @default(0)
  totalAttempts    Int @default(0)
  successfulSolves Int @default(0)
  commentsCount    Int @default(0)
  sharesCount      Int @default(0)

  // relations
  author      User            @relation(fields: [authorId], references: [id])
  tags        ProblemTag[]
  testCases   TestCase[]
  submissions Submission[]
  likes       Like[]
  comments    Comment[]
  solvedBy    SolvedProblem[]
  bookmarks   Bookmark[]
  sharedInMessages Message[]

  @@index([authorId])
  @@index([difficulty])
  @@index([createdAt])
}

// ══════════════════════════════════════════════
//  TAG
// ══════════════════════════════════════════════
model Tag {
  id       String       @id @default(cuid())
  name     String       @unique // "Arrays", "Dynamic Programming", etc.
  problems ProblemTag[]
}

// ══════════════════════════════════════════════
// ProblemTag is a join table that connects Problems and Tags in a many-to-many relationship
// ══════════════════════════════════════════════
model ProblemTag {
  problemId String
  tagId     String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([problemId, tagId])
}

model Bookmark {
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([userId, problemId])
  @@index([problemId])
}

// ══════════════════════════════════════════════
//  TEST CASE
//  stdin / stdout format
// ══════════════════════════════════════════════
model TestCase {
  id             String  @id @default(cuid())
  problemId      String
  label          String? // "Case 1", "Case 2"
  input          String  @db.Text // stdin
  expectedOutput String  @db.Text // stdout
  isHidden       Boolean @default(false) // hidden = judge only, not shown to solver
  orderIndex     Int     @default(0)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

// ══════════════════════════════════════════════
//  SUBMISSION
//  One row per Run or Submit click
// ══════════════════════════════════════════════
model Submission {
  id           String           @id @default(cuid())
  userId       String
  problemId    String
  language     String // "python", "javascript", etc.
  code         String           @db.Text
  type         SubmissionType   @default(SUBMIT) // RUN = test only, SUBMIT = judge all
  status       SubmissionStatus
  runtime      Float? // ms
  memory       Float? // MB
  errorMessage String?          @db.Text
  submittedAt  DateTime         @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@index([userId])
  @@index([problemId])
  @@index([userId, problemId]) // fast "has this user solved this problem" lookup
}

// ══════════════════════════════════════════════
//  FOLLOW
// ══════════════════════════════════════════════
model Follow {
  followerId  String // the user doing the following
  followingId String // the user being followed
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ══════════════════════════════════════════════
//  LIKE
// ══════════════════════════════════════════════
model Like {
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([userId, problemId])
}

// ══════════════════════════════════════════════
//  COMMENT
// ══════════════════════════════════════════════
model Comment {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

// ══════════════════════════════════════════════
//  NOTIFICATION
//  Covers: new follower, like on user problem,
//          comment on user problem, new submission result
// ══════════════════════════════════════════════
model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  read        Boolean          @default(false)
  // flexible payload: { actorId, problemId, commentId, etc. }
  payload     Json
  createdAt   DateTime         @default(now())

  recipient User @relation("recipient", fields: [recipientId], references: [id])

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
}

// ══════════════════════════════════════════════
//  SOLVED PROBLEM
// ══════════════════════════════════════════════
model SolvedProblem {
  userId      String
  problemId   String
  solvedAt    DateTime @default(now())
  bestRuntime Float?
  bestMemory  Float?

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@id([userId, problemId])
  @@index([userId])
  @@index([problemId])
}

// ══════════════════════════════════════════════
//  MESSAGING MODELS
// ══════════════════════════════════════════════

model Conversation {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime?
  lastMessagePreview String? // "Hey, check this problem..." — for messageSidebar

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  unreadCount    Int      @default(0)
  lastSeenAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType   @default(TEXT)
  body           String?       @db.Text          // null for shared_post-only messages
  problemId      String?                         // set when type = SHARED_POST
  status         MessageStatus @default(SENT)
  seenAt         DateTime?
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  problem      Problem?     @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ══════════════════════════════════════════════
//  ENUMS
// ══════════════════════════════════════════════
enum Difficulty {
  Easy
  Medium
  Hard
}

enum SubmissionType {
  RUN
  SUBMIT
}

enum SubmissionStatus {
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  COMPILATION_ERROR
}

enum NotificationType {
  NEW_FOLLOWER
  PROBLEM_LIKED
  PROBLEM_COMMENTED
  PROBLEM_SOLVED
  SUBMISSION_RESULT
}

enum MessageType {
  TEXT
  SHARED_POST
}

enum MessageStatus {
  SENT
  DELIVERED
  SEEN
}